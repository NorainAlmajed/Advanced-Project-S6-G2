@model IEnumerable<AdvancedProject.Models.Lease>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-controller="Properties" asp-action="Index">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.LeaseId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Tenant.User.FullName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Unit.UnitNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
               Duration (Months)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MonthlyRent)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.LeaseId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Tenant.User.FullName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Unit.UnitNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StartDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EndDate)
            </td>
            <td>
                    @Html.DisplayFor(modelItem => item.Duration.Months)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MonthlyRent)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.LeaseId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.LeaseId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.LeaseId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
