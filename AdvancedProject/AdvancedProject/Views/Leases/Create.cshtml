@model AdvancedProject.Models.Lease

@{
    ViewData["Title"] = "Create Lease";
}

<div class="lease-form-page">
    <div class="lease-form-wrapper">
        <div class="lease-form-card shadow-soft">
            <div class="lease-form-header">
                <p class="lease-form-eyebrow mb-2">Lease</p>
                <h1 class="lease-form-title mb-2">@ViewBag.PropertyName - Unit @ViewBag.UnitNumber</h1>
                <p class="lease-form-subtitle mb-0">
                    Select the tenant, start date, and lease duration to create the lease.
                </p>
            </div>

            <form asp-action="Create" asp-controller="Leases" method="post" class="lease-form-body">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" name="UnitId" value="@Model.UnitId" />

                <div class="lease-form-group">
                    <label asp-for="TenantId" class="lease-form-label">Tenant Username</label>

                    <select asp-for="TenantId"
                            id="tenantSelect"
                            class="form-select lease-form-input searchable-select"
                            asp-items="ViewBag.TenantName">
                        <option value="">-- Select Username --</option>
                    </select>

                    <span asp-validation-for="TenantId" class="text-danger small"></span>
                </div>

                <div class="lease-form-group">
                    <label asp-for="StartDate" class="lease-form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control lease-form-input" />
                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                </div>

                <div class="lease-form-group">
                    <label asp-for="DurationId" class="lease-form-label">Duration</label>
                    <select asp-for="DurationId" class="form-select lease-form-input" asp-items="ViewBag.DurationId">
                        ect lease-form-input" asp-items="ViewBag.DurationId">
                        <option value="">-- Select Duration --</option>
                    </select>
                    <span asp-validation-for="DurationId" class="text-danger small"></span>
                </div>

                <div class="lease-form-actions">
                    <button type="submit" class="btn btn-primary lease-submit-btn">
                        Create Lease
                    </button>

                    <a asp-action="Index" class="lease-back-link">
                        Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const tenantSelect = document.getElementById("tenantSelect");

            if (tenantSelect) {
                new Choices(tenantSelect, {
                    searchEnabled: true,
                    itemSelectText: '',
                    shouldSort: false,
                    searchPlaceholderValue: 'Search username...',
                    placeholder: true
                });
            }
        });
    </script>
}