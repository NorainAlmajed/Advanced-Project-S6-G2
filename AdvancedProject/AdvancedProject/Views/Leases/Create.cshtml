@model AdvancedProject.Models.Lease

@{
    ViewData["Title"] = "Create Lease";
}

<h1>Create Lease</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" asp-controller="Leases" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" name="UnitId" value="@Model.UnitId" />
            <div class="form-group">
                <label asp-for="TenantId" class="control-label"></label>

                <select asp-for="TenantId" class="form-control" asp-items="ViewBag.TenantName">
                    <option value="">-- Select Username --</option>
                </select>

                <span asp-validation-for="TenantId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StartDate" class="control-label"></label>
                <input asp-for="StartDate" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DurationId" class="control-label"></label>
                <select asp-for="DurationId" class="form-control" asp-items="ViewBag.DurationId">
                    <option value="">-- Select Duration --</option>
                </select>
                <span asp-validation-for="DurationId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
