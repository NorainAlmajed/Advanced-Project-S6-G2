<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rentify</title>
    <link rel="icon" type="image/png" sizes="1000x1000" href="~/images/logo.png" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AdvancedProject.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />

</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Rentify
                </a>

                <button class="navbar-toggler app-navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto align-items-lg-center nav-pill-group">
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Users" asp-action="Index">Users</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Properties" asp-action="Index">Properties</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="LeaseApplications" asp-action="Index">Applications</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Leases" asp-action="Index">Leases</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="MaintenanceRequests" asp-action="Index">Requests</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Payments" asp-action="Index">Payments</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link notification-bell-link"
                               asp-controller="Notifications"
                               asp-action="Index"
                               title="Notifications">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">

                                    <!-- bell body -->
                                    <path d="M12 2a5 5 0 0 0-5 5v3c0 .8-.3 1.5-.8 2.1L5 14h14l-1.2-1.9c-.5-.6-.8-1.3-.8-2.1V7a5 5 0 0 0-5-5z" />

                                    <!--  moved UP (was 18 → now 16.5) -->
                                    <path d="M9 16a3 3 0 0 0 6 0H9z" />
                                </svg>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-main-container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container">
            <span>&copy; 2026 - AdvancedProject</span>
            <span class="footer-divider">•</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>