@model IEnumerable<AdvancedProject.Models.Property>

@{
    ViewData["Title"] = "Index";
}

<h1 class="mb-4">Properties</h1>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3">Find a Property</h5>

        <form asp-action="Index" method="get">
            <div class="row g-2 align-items-center">
                <div class="col-md-8">
                    <input type="text"
                           name="searchString"
                           class="form-control form-control-lg"
                           placeholder="Search by property name or city..."
                           value="@Context.Request.Query["searchString"]" />
                </div>

                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        Search
                    </button>
                </div>

                <div class="col-md-2 d-grid">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                        Reset
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">
                        @Html.DisplayFor(modelItem => item.Name)
                    </h5>

                    <h6 class="card-subtitle mb-2 text-muted">
                        @Html.DisplayFor(modelItem => item.City)
                    </h6>

                    <p class="card-text">
                        @Html.DisplayFor(modelItem => item.Description)
                    </p>

                    @* <p class="card-text">
                    <strong>@Html.DisplayNameFor(model => model.First().CreatedAt):</strong>
                    @Html.DisplayFor(modelItem => item.CreatedAt)
                </p> *@

                    @* <p class="card-text">
                    <strong>@Html.DisplayNameFor(model => model.First().Block):</strong>
                    @Html.DisplayFor(modelItem => item.Block)
                </p>
                <p class="card-text">
                    <strong>@Html.DisplayNameFor(model => model.First().Building):</strong>
                    @Html.DisplayFor(modelItem => item.Building)
                </p>
                <p class="card-text">
                    <strong>@Html.DisplayNameFor(model => model.First().Road):</strong>
                    @Html.DisplayFor(modelItem => item.Road)
                </p> *@
                </div>

                <div class="card-footer bg-white border-top-0">
                    <a asp-action="Details" asp-route-id="@item.PropertyId" class="btn btn-outline-primary btn-sm">
                        Details
                    </a>

                    <a asp-controller="Units" asp-action="Index" asp-route-id="@item.PropertyId" class="btn btn-outline-success btn-sm ms-2">
                        View Units
                    </a>
                </div>
            </div>
        </div>
    }
</div>