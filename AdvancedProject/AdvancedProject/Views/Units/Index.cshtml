@model IEnumerable<AdvancedProject.Models.Unit>

@{
    ViewData["Title"] = "Index";
    var currentStatus = ViewBag.CurrentStatus as string ?? "All";
    var propertyId = ViewBag.PropertyId;
    var selectedAmenities = ViewBag.SelectedAmenities as int[] ?? Array.Empty<int>();
    var amenityList = ViewBag.AmenityList as List<AdvancedProject.Models.Amenity> ?? new List<AdvancedProject.Models.Amenity>();
}

<h1 class="mb-4">
    @if (ViewBag.PropertyName != null)
    {
        <span>@ViewBag.PropertyName Units</span>
    }
    else
    {
        <span>Units</span>
    }
</h1>

<form asp-action="Index" method="get" class="mb-4">
    <input type="hidden" name="id" value="@propertyId" />

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-lg-4">
                    <label class="form-label fw-semibold">Search</label>
                    <input type="text"
                           name="searchString"
                           class="form-control"
                           placeholder="Search by unit number or type."
                           value="@ViewBag.CurrentSearch" />
                </div>

                <div class="col-lg-2">
                    <label class="form-label fw-semibold">Property Type</label>
                    <select name="typeFilter" class="form-select" asp-items="ViewBag.TypeList">
                        <option value="">All Types</option>
                    </select>
                </div>

                <div class="col-lg-2">
                    <label class="form-label fw-semibold">Price Range</label>
                    <select name="priceFilter" class="form-select">
                        <option value="">All Prices</option>
                        <option value="Under300" selected="@(ViewBag.CurrentPrice == "Under300")">Under 300</option>
                        <option value="300to400" selected="@(ViewBag.CurrentPrice == "300to400")">300 to 400</option>
                        <option value="401to500" selected="@(ViewBag.CurrentPrice == "401to500")">401 to 500</option>
                        <option value="Above500" selected="@(ViewBag.CurrentPrice == "Above500")">Above 500</option>
                    </select>
                </div>

                <div class="col-lg-2">
                    <label class="form-label fw-semibold">Amenities</label>
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                type="button"
                                data-bs-toggle="dropdown"
                                data-bs-auto-close="outside"
                                aria-expanded="false">
                            Select Amenities
                        </button>

                        <div class="dropdown-menu p-3 w-100" style="min-width: 260px;">
                            @if (amenityList.Any())
                            {
                                @foreach (var amenity in amenityList)
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="selectedAmenities"
                                               value="@amenity.AmenityId"
                                               id="amenity_@amenity.AmenityId"
                                               @(selectedAmenities.Contains(amenity.AmenityId) ? "checked" : "") />
                                        <label class="form-check-label" for="amenity_@amenity.AmenityId">
                                            @amenity.Name
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <span class="text-muted">No amenities available</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-lg-1 d-grid">
                    <button type="submit" class="btn btn-primary">
                        Apply
                    </button>
                </div>

                <div class="col-lg-1 d-grid">
                    <a asp-action="Index" asp-route-id="@propertyId" class="btn btn-outline-secondary">
                        Reset
                    </a>
                </div>
            </div>

            <div class="mt-3">
                <label class="form-label fw-semibold d-block mb-2">Status</label>

                <div class="btn-group" role="group">
                    <input type="radio" class="btn-check" name="statusFilter" id="statusAll" value="All" @(currentStatus == "All" ? "checked" : "")>
                    <label class="btn btn-outline-dark" for="statusAll">All Units</label>

                    <input type="radio" class="btn-check" name="statusFilter" id="statusAvailable" value="Available" @(currentStatus == "Available" ? "checked" : "")>
                    <label class="btn btn-outline-success" for="statusAvailable">Available</label>

                    <input type="radio" class="btn-check" name="statusFilter" id="statusOccupied" value="Occupied" @(currentStatus == "Occupied" ? "checked" : "")>
                    <label class="btn btn-outline-danger" for="statusOccupied">Occupied</label>
                </div>
            </div>
        </div>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-light border">
        No units found matching the selected filters.
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-sm-12 col-md-6 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm">

                    <div class="card-body">
                        <h5 class="card-title">
                            Unit @Html.DisplayFor(modelItem => item.UnitNumber)
                        </h5>

                        <h6 class="card-subtitle mb-2 text-muted">
                            @item.UnitType?.Name
                        </h6>

                        <p class="card-text">
                            <strong>Size:</strong> @Html.DisplayFor(modelItem => item.SizeSqFt) SqFt
                        </p>

                        <p class="card-text">
                            <strong>Rent:</strong> @Html.DisplayFor(modelItem => item.RentAmount)
                        </p>

                        <p class="card-text">
                            <strong>Status:</strong>

                            @if (item.AvailabilityStatus == "Available")
                            {
                                <span class="badge bg-success">Available</span>
                            }
                            else if (item.AvailabilityStatus == "Occupied")
                            {
                                <span class="badge bg-danger">Occupied</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    @item.AvailabilityStatus
                                </span>
                            }
                        </p>

                        <p class="card-text mb-2">
                            <strong>Amenities:</strong>
                        </p>

                        @if (item.Amenities != null && item.Amenities.Any())
                        {
                            <div class="mb-2">
                                @foreach (var amenity in item.Amenities)
                                {
                                    <span class="badge bg-secondary me-1 mb-1">@amenity.Name</span>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No amenities available</p>
                        }
                    </div>

                    <div class="card-footer bg-white border-top-0">
                        <a asp-action="Details"
                           asp-route-id="@item.UnitId"
                           asp-route-propertyId="@item.PropertyId"
                           class="btn btn-outline-primary btn-sm">
                            Details
                        </a>

                        <a asp-controller="LeaseApplications"
                           asp-action="Create"
                           asp-route-unitId="@item.UnitId"
                           class="btn btn-outline-success btn-sm ms-2">
                            Apply
                        </a>
                        <a asp-controller="Leases"
                           asp-action="Create"
                           asp-route-unitId="@item.UnitId"
                           class="btn btn-outline-success btn-sm ms-2">
                            Apply
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>
}