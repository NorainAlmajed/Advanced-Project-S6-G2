@model IEnumerable<AdvancedProject.Models.Unit>

@{
    ViewData["Title"] = "Index";
}

<h1 class="mb-4">
    @if (ViewBag.PropertyName != null)
    {
        <span>@ViewBag.PropertyName Units</span>
    }
    else
    {
        <span>Units</span>
    }
</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card h-100 shadow-sm">

                <div class="card-body">
                    <h5 class="card-title">
                        Unit @Html.DisplayFor(modelItem => item.UnitNumber)
                    </h5>

                    <h6 class="card-subtitle mb-2 text-muted">
                        @Html.DisplayFor(modelItem => item.Type)
                    </h6>

                    <p class="card-text">
                        <strong>Size:</strong> @Html.DisplayFor(modelItem => item.SizeSqFt) SqFt
                    </p>

                    <p class="card-text">
                        <strong>Rent:</strong> @Html.DisplayFor(modelItem => item.RentAmount)
                    </p>

                    <p class="card-text">
                        <strong>Status:</strong>

                        @if (item.AvailabilityStatus == "Available")
                        {
                            <span class="badge bg-success">Available</span>
                        }
                        else if (item.AvailabilityStatus == "Occupied")
                        {
                            <span class="badge bg-danger">Occupied</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                @item.AvailabilityStatus
                            </span>
                        }
                    </p>

                    <p class="card-text mb-2">
                        <strong>Amenities:</strong>
                    </p>

                    @if (item.Amenities != null && item.Amenities.Any())
                    {
                        <div class="mb-2">
                            @foreach (var amenity in item.Amenities)
                            {
                                <span class="badge bg-secondary me-1 mb-1">@amenity.Name</span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No amenities available</p>
                    }
                </div>

                <div class="card-footer bg-white border-top-0">
                    <a asp-action="Details" asp-route-id="@item.UnitId" asp-route-propertyId="@item.PropertyId" class="btn btn-outline-primary btn-sm">
                        Details
                    </a>

                    <a asp-controller="LeaseApplications"
                       asp-action="Create"
                       asp-route-unitId="@item.UnitId"
                       class="btn btn-outline-success btn-sm ms-2">
                        Apply
                    </a>
                </div>

            </div>
        </div>
    }
</div>