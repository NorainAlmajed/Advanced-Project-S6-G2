@model IEnumerable<AdvancedProject.Models.MaintenanceStaff>
@using AdvancedProject.Models

@{
    ViewData["Title"] = "Maintenance Staff";

    string currentSearch = ViewData["CurrentSearchTerm"]?.ToString() ?? "";
    string currentAvailability = ViewData["CurrentAvailabilityFilter"]?.ToString() ?? "";
    var currentSkillIds = ViewData["CurrentSkillIds"] as List<int> ?? new List<int>();
    var skillsList = ViewData["Skills"] as List<Skill> ?? new List<Skill>();
    string skillMatchMessage = ViewData["SkillMatchMessage"]?.ToString() ?? "";

    string selectedSkillsText = currentSkillIds.Any()
        ? $"{currentSkillIds.Count} skill(s) selected"
        : "All Skills";
}

<div class="container py-4 users-page">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-4">
        <div>
            <p class="details-eyebrow mb-1">Maintenance Team</p>
            <h1 class="details-title mb-2">Maintenance Staff</h1>
            <p class="users-subtitle mb-0">Browse and manage maintenance staff by availability and skill.</p>
        </div>

        <a asp-action="Create" class="btn btn-light-custom users-create-btn">
            + Add New Staff
        </a>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a asp-controller="Users"
           asp-action="Index"
           class="btn btn-light-custom users-filter-btn">
            All Users
        </a>

        <a asp-controller="Users"
           asp-action="Index"
           asp-route-roleFilter="Tenant"
           class="btn btn-light-custom users-filter-btn">
            Tenants
        </a>

        <a asp-action="Index"
           class="btn btn-primary users-filter-btn">
            Maintenance Staff
        </a>
    </div>

    <div class="card search-card shadow-soft border-0 mb-4 users-search-card">
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-lg-5">
                    <label for="searchTerm" class="form-label fw-semibold">Search Staff</label>
                    <input type="text"
                           id="searchTerm"
                           name="searchTerm"
                           value="@currentSearch"
                           class="form-control form-control-lg users-search-input"
                           placeholder="Search by username, full name, email, phone, or role..." />
                </div>

                <div class="col-lg-3">
                    <label for="availabilityFilter" class="form-label fw-semibold">Availability</label>
                    <select id="availabilityFilter" name="availabilityFilter" class="form-select form-select-lg users-search-input">
                        <option value="">All Statuses</option>
                        <option value="Available" selected="@(currentAvailability == "Available")">Available</option>
                        <option value="Busy" selected="@(currentAvailability == "Busy")">Busy</option>
                    </select>
                </div>

                <div class="col-lg-2">
                    <label class="form-label fw-semibold">Skill</label>
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                type="button"
                                id="skillsDropdownButton"
                                data-bs-toggle="dropdown"
                                data-bs-auto-close="outside"
                                aria-expanded="false">


                            <span id="skillsDropdownText">@selectedSkillsText</span>
                        </button>

                        <div class="dropdown-menu p-3 w-100" style="min-width: 260px; max-height: 260px; overflow-y: auto;">
                            @if (skillsList.Any())
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" value="" id="selectAllSkills">
                                    <label class="form-check-label fw-semibold" for="selectAllSkills">
                                        Select / Clear All
                                    </label>
                                </div>

                                <hr class="my-2" />

                                @foreach (var skill in skillsList)
                                {
                                    bool isChecked = currentSkillIds.Contains(skill.SkillId);

                                    <div class="form-check mb-2">
                                        <input class="form-check-input skill-checkbox"
                                               type="checkbox"
                                               name="skillIds"
                                               value="@skill.SkillId"
                                               id="skill_@skill.SkillId"
                                               @(isChecked ? "checked" : "") />
                                        <label class="form-check-label" for="skill_@skill.SkillId">
                                            @skill.Name
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <span class="text-muted">No skills available</span>
                            }
                        </div>
                    </div>
                </div>



                <div class="col-lg-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary users-search-btn flex-fill">
                        Search
                    </button>

                    <a asp-action="Index" class="btn btn-outline-light users-reset-btn flex-fill">
                        Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(skillMatchMessage))
    {
        <div class="alert alert-warning shadow-soft border-0 mb-4">
            @skillMatchMessage
        </div>
    }

    <div class="card shadow-soft border-0 users-table-card">
        <div class="table-responsive">
            <table class="table mb-0 users-table align-middle">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Role</th>
                        <th>Availability</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            string availabilityClass = item.AvailabilityStatus?.ToLower() == "available"
                            ? "badge-soft-active"
                            : item.AvailabilityStatus?.ToLower() == "busy"
                            ? "badge-soft-inactive"
                            : "badge-soft-default";

                            <tr class="users-row">
                                <td class="fw-semibold">@item.User.Username</td>
                                <td>@item.User.FullName</td>
                                <td>@item.User.Email</td>
                                <td>@item.User.Phone</td>
                                <td>
                                    <span class="custom-pill badge-soft-staff">
                                        @item.User.Role
                                    </span>
                                </td>
                                <td>
                                    <span class="custom-pill @availabilityClass">
                                        @item.AvailabilityStatus
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.StaffId" class="btn btn-primary btn-sm users-details-btn">
                                        View Details
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                No maintenance staff found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const skillCheckboxes = document.querySelectorAll(".skill-checkbox");
            const selectAllCheckbox = document.getElementById("selectAllSkills");
            const dropdownText = document.getElementById("skillsDropdownText");

            function updateDropdownText() {
                const checked = document.querySelectorAll(".skill-checkbox:checked");
                const count = checked.length;

                if (count === 0) {
                    dropdownText.textContent = "All Skills";
                } else if (count === 1) {
                    const label = checked[0].closest(".form-check").querySelector("label").textContent.trim();
                    dropdownText.textContent = label;
                } else {
                    dropdownText.textContent = count + " skills selected";
                }

                selectAllCheckbox.checked = count === skillCheckboxes.length && skillCheckboxes.length > 0;
            }

            if (selectAllCheckbox) {
                selectAllCheckbox.addEventListener("change", function () {
                    skillCheckboxes.forEach(cb => cb.checked = selectAllCheckbox.checked);
                    updateDropdownText();
                });
            }

            skillCheckboxes.forEach(cb => {
                cb.addEventListener("change", function () {
                    updateDropdownText();
                });
            });

            updateDropdownText();
        });
    </script>
}