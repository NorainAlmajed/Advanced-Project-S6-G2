@model AdvancedProject.Models.Tenant

@{
    ViewData["Title"] = "Tenant Details";

    string fullName = Model.User?.FullName ?? "Tenant";
    string username = Model.User?.Username ?? "-";
    string email = Model.User?.Email ?? "-";
    string phone = Model.User?.Phone ?? "-";
    string role = Model.User?.Role ?? "Tenant";

    string initials = "";
    if (!string.IsNullOrWhiteSpace(fullName))
    {
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        initials = string.Concat(parts.Take(2).Select(p => char.ToUpper(p[0])));
        initials = string.Concat(parts.Take(2).Select(p => char.ToUpper(p[0])));
    }

    string dobText = Model.Dob.ToString("dd MMM yyyy");
    string createdAtText = Model.User != null ? Model.User.CreatedAt.ToString("dd MMM yyyy") : "Not available";
    string genderClass = Model.User?.Gender == "F" ? "badge-gender-female" : "badge-gender-male";
    string genderText = Model.User?.Gender == "F" ? "Female" : "Male";
}


<div class="details-page container py-4">
    <div class="details-topbar d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <p class="details-eyebrow mb-1">Tenant Portal</p>
            <h1 class="details-title mb-0">Tenant Details</h1>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Edit" asp-route-id="@Model.TenantId" class="btn btn-accent details-btn">
                Edit Tenant Info
            </a>
            <a asp-controller="Users" asp-action="Index" class="btn btn-light-custom details-btn">
                Back to Users
            </a>
        </div>
    </div>

    <div class="card details-main-card shadow-soft border-0">
        <div class="card-body p-4 p-lg-5">
            <div class="row g-4">
                <div class="col-12">
                    <div class="tenant-hero-card">
                        <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center gap-4">
                            <div class="profile-avatar tenant-avatar">
                                @initials
                            </div>

                            <div class="flex-grow-1">
                                <h2 class="profile-name mb-2">@fullName</h2>

                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <span class="custom-pill badge-soft-tenant">@role</span>
                                    <span class="custom-pill @genderClass">@genderText</span>
                                </div>

                                <div class="hero-contact-grid">
                                    <div class="hero-contact-item">
                                        <span class="info-label">Username</span>
                                        <span class="info-value">@username</span>
                                    </div>

                                    <div class="hero-contact-item">
                                        <span class="info-label">Email Address</span>
                                        <span class="info-value">@email</span>
                                    </div>

                                    <div class="hero-contact-item">
                                        <span class="info-label">Phone Number</span>
                                        <span class="info-value">@phone</span>
                                    </div>

                                    <div class="hero-contact-item">
                                        <span class="info-label">Date of Birth</span>
                                        <span class="info-value">@dobText</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="details-section-card mt-4">
                        <div class="section-header">
                            <h3>Tenant Information</h3>
                            <p>Personal details and tenant-specific records.</p>
                        </div>

                        <div class="info-grid">
                            <div class="info-box">
                                <span class="info-label">National ID</span>
                                <span class="info-value">@(string.IsNullOrWhiteSpace(Model.NationalId) ? "Not available" : Model.NationalId)</span>
                            </div>

                            <div class="info-box">
                                <span class="info-label">Account Created</span>
                                <span class="info-value">@createdAtText</span>
                            </div>
                        </div>
                    </div>

                    <div class="details-section-card mt-4">
                        <div class="section-header">
                            <h3>Contact Details</h3>
                            <p>Quick reference for communication details.</p>
                        </div>

                        <div class="contact-mini-grid">
                            <div class="contact-mini-card">
                                <span class="info-label">Email</span>
                                <span class="info-value">@email</span>
                            </div>

                            <div class="contact-mini-card">
                                <span class="info-label">Phone</span>
                                <span class="info-value">@phone</span>
                            </div>

                            <div class="contact-mini-card">
                                <span class="info-label">Username</span>
                                <span class="info-value">@username</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>