@model AdvancedProject.Models.LeaseApplication

@{
    ViewData["Title"] = "Apply for Lease";
}

<div class="lease-form-page">
    <div class="lease-form-wrapper">
        <div class="lease-form-card shadow-soft">
            <div class="lease-form-header">
                <p class="lease-form-eyebrow mb-2">Lease Application</p>
                <h1 class="lease-form-title mb-2">@ViewBag.PropertyName - Unit @ViewBag.UnitNumber</h1>              
                <p class="lease-form-subtitle mb-0">
                    Select your preferred start date and lease duration for this unit.
                </p>
            </div>

            <form asp-action="Create" method="post" class="lease-form-body">
                <input type="hidden" asp-for="UnitId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="lease-form-group">
                    <label asp-for="StartDate" class="lease-form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control lease-form-input" />
                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                </div>

                <div class="lease-form-group">
                    <label asp-for="DurationId" class="lease-form-label">Duration</label>
                    <select asp-for="DurationId" class="form-select lease-form-input" asp-items="ViewBag.DurationId">
                        <option value="">-- Select Duration --</option>
                    </select>
                    <span asp-validation-for="DurationId" class="text-danger small"></span>
                </div>

                <div class="lease-form-actions">
                    <button type="submit" class="btn btn-primary lease-submit-btn">
                        Submit Application
                    </button>

                    <a asp-action="Index" class="lease-back-link">
                        Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}