@model IEnumerable<AdvancedProject.Models.Payment>

@{
    ViewData["Title"] = "Payments";

    var currentSearchTerm = ViewData["CurrentSearchTerm"]?.ToString();
    var currentStatusFilter = ViewData["CurrentStatusFilter"]?.ToString();
    var currentDateFilter = ViewData["CurrentDateFilter"]?.ToString();
    var totalPayments = ViewData["TotalPayments"] ?? 0;
}

<div class="payments-page">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="details-title mb-2">Payments</h1>
            <p class="users-subtitle mb-0">
                Browse and manage payments by payment ID, lease ID, amount, and status.
            </p>
        </div>
    </div>

    <div class="card search-card users-search-card shadow-soft border-0 mb-4">
        <div class="card-body p-4">
            <form asp-action="Index" method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-lg-5">
                        <label class="form-label fw-semibold text-white">Search Payments</label>
                        <input type="text"
                               name="searchTerm"
                               value="@currentSearchTerm"
                               class="form-control users-search-input"
                               placeholder="Search by payment ID or lease ID..." />
                    </div>

                    <div class="col-lg-2">
                        <label class="form-label fw-semibold text-white">Status</label>
                        <select name="statusFilter" class="form-select users-search-input">
                            <option value="">All Statuses</option>
                            <option value="Pending" selected="@(currentStatusFilter == "Pending")">Pending</option>
                            <option value="Paid" selected="@(currentStatusFilter == "Paid")">Paid</option>
                            <option value="Late" selected="@(currentStatusFilter == "Late")">Late</option>
                        </select>
                    </div>

                    <div class="col-lg-2">
                        <label class="form-label fw-semibold text-white">Start Date</label>
                        <select name="dateFilter" class="form-select users-search-input">
                            <option value="">All Dates</option>
                            <option value="Latest" selected="@(currentDateFilter == "Latest")">Latest</option>
                            <option value="Oldest" selected="@(currentDateFilter == "Oldest")">Oldest</option>
                        </select>
                    </div>

                    <div class="col-lg-1">
                        <div class="payment-total-box">
                            <span class="payment-total-label">Total</span>
                            <span class="payment-total-value">@totalPayments</span>
                        </div>
                    </div>

                    <div class="col-lg-1">
                        <button type="submit" class="btn btn-primary users-search-btn w-100">
                            Search
                        </button>
                    </div>

                    <div class="col-lg-1">
                        <a asp-action="Index" class="btn btn-outline-light users-reset-btn w-100">
                            Reset
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="users-table-card">
        <div class="table-responsive">
            <table class="table users-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Payment ID</th>
                        <th>Lease ID</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.PaymentId</td>
                                <td>@item.Lease.LeaseId</td>
                                <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                                <td>@item.EndDate.ToString("dd MMM yyyy")</td>
                                <td>@item.Amount.ToString("0.00")</td>
                                <td>
                                    @if (item.Status == "Paid")
                                    {
                                        <span class="custom-pill payment-status-paid">Paid</span>
                                    }
                                    else if (item.Status == "Pending")
                                    {
                                        <span class="custom-pill payment-status-pending">Pending</span>
                                    }
                                    else if (item.Status == "Late")
                                    {
                                        <span class="custom-pill payment-status-late">Late</span>
                                    }
                                    else
                                    {
                                        <span class="custom-pill badge-soft-default">@item.Status</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details"
                                       asp-route-id="@item.PaymentId"
                                       class="btn payment-details-btn">
                                        View Details
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4">
                                No payments found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>