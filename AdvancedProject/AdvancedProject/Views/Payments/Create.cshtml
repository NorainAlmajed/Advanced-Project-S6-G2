@model AdvancedProject.Models.Payment

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Payment</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="LeaseId" class="control-label"></label>
                <select asp-for="LeaseId" class="form-control" asp-items="ViewBag.LeaseId">
                    <option value="">-- Select Lease --</option>
                </select>
                <span asp-validation-for="LeaseId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StartDate" class="control-label"></label>
                <input asp-for="StartDate" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PaymentFrequencyId" class="control-label"></label>
                <select asp-for="PaymentFrequencyId"
                        class="form-control"
                        asp-items="ViewBag.PaymentFrequencyId">
                    <option value="">-- Select Frequency --</option>
                </select>
                <span asp-validation-for="PaymentFrequencyId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PaymentMethodId" class="control-label"></label>
                <select asp-for="PaymentMethodId"
                        class="form-control"
                        asp-items="ViewBag.PaymentMethodId">
                    <option value="">-- Select Payment Method --</option>
                </select>
                <span asp-validation-for="PaymentMethodId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status"
                        class="form-control"
                        asp-items="ViewBag.StatusList">
                    <option value="">-- Select Status --</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
